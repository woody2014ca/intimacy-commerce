# =========================
#  Runtime
# =========================
NODE_ENV=development
APP_NAME=intimacy-commerce
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
PORT=4000

# 线上 CORS：允许的前端来源，多个用英文逗号分隔（如 https://shop.kunlunfo.com）。不设则开发环境允许任意
# CORS_ORIGIN=https://shop.kunlunfo.com

# =========================
#  Database (PostgreSQL)
# =========================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intimacy_commerce?schema=public

# =========================
#  Auth (JWT)
# =========================
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookie settings (for admin/web)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Rate limit (basic)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# =========================
#  Feature Flags (Phase 1 recommended)
# =========================
FEATURE_PAGE_BUILDER=true
FEATURE_CONTENT=true
FEATURE_MEMBERSHIP=true
FEATURE_POINTS=true
FEATURE_COUPON=true
FEATURE_GIFTCARD=true
FEATURE_ASSIST_CAMPAIGN=true

FEATURE_BALANCE=false
FEATURE_COD=false
FEATURE_MULTI_MERCHANT=false
FEATURE_MULTI_CITY=true
FEATURE_MULTI_STORE=false
FEATURE_PICKUP_VERIFY=false
FEATURE_POS=false
FEATURE_E_SIGN=false
FEATURE_CUSTOM_FORM=true

# =========================
#  Compliance / Safety (Hard Limits)
# =========================
# IMPORTANT: referral depth is hard-capped in code too
MAX_REF_DEPTH=2

# Supplier view masking
SUPPLIER_VIEW_MASK_PHONE=true

# Audit logs
AUDIT_LOG_RETENTION_DAYS=365

# =========================
#  Commerce - Primary Product (Single flagship)
# =========================
PRIMARY_PRODUCT_NAME=亲密升级礼盒（调情香氛套装）
PRIMARY_PRODUCT_PRICE=2180
PRIMARY_PRODUCT_SKU=GIFTBOX-2180
PRIMARY_PRODUCT_LIMIT_PER_USER=2
PRIMARY_PRODUCT_LIMIT_PERIOD=DAYS_30
STOCK_ALERT_THRESHOLD=30

# =========================
#  Commission & Settlement (2-level only)
# =========================
COMMISSION_LEVEL1_RATE=0.18
COMMISSION_LEVEL2_RATE=0.06

COMMISSION_FREEZE_DAYS=10
COMMISSION_TRIGGER_STATUS=COMPLETED

# Withdrawal
WITHDRAW_MIN_AMOUNT=200
WITHDRAW_FEE_RATE=0.00
WITHDRAW_REVIEW_MODE=MANUAL
WITHDRAW_DAILY_LIMIT=20000

# Cron schedules (server local time)
CRON_SETTLEMENT=0 3 * * *
CRON_FREEZE_EXPIRE=30 3 * * *
CRON_REPORTS=0 4 * * *

# =========================
#  Coupons (suggested presets)
# =========================
COUPON_NEW_USER_AMOUNT=100
COUPON_REPEAT_AMOUNT=200
COUPON_ASSIST_AMOUNT=300
COUPON_MIN_ORDER_AMOUNT=2180

# =========================
#  Membership (VIP)
# =========================
VIP_PRICE=299
VIP_DURATION_DAYS=365
VIP_ORDER_DISCOUNT=50

# =========================
#  Login Review (recommended ON for phase1)
# =========================
LOGIN_REVIEW_ENABLED=true
REVIEW_MODE=INVITE_ONLY
INVITE_CODE_REQUIRED=true

# =========================
#  Shipping / Privacy (sensitive category)
# =========================
PACKAGE_DISPLAY_NAME=日用品
SENDER_DISPLAY_NAME=某某贸易
ORDER_PRIVACY_MODE_DEFAULT=true

# =========================
#  Uploads (local)
# =========================
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# =========================
#  SMS Provider (mock in phase1)
# =========================
SMS_PROVIDER=mock
SMS_MOCK_CODE=123456

# =========================
#  Payment (Sandbox)
# =========================
PAY_PROVIDER=sandbox
PAY_SANDBOX_SUCCESS=true

# =========================
#  Admin bootstrap
# =========================
# On first boot, system prints SUPER_ADMIN credentials and requires password change
BOOTSTRAP_SUPER_ADMIN=true
BOOTSTRAP_SUPER_ADMIN_EMAIL=superadmin@example.com
BOOTSTRAP_SUPER_ADMIN_PHONE=18800000000
